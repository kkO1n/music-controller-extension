{
  "manifest_version": 3,
  "name": "Simple Firefox Popup",
  "version": "0.1.0",
  "description": "Tracks current song on music.yandex.ru and shows it in popup.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://music.yandex.ru/*", "https://api.telegram.org/*"],
  "background": {
    "scripts": ["background/telegram-bridge.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://music.yandex.ru/*"],
      "js": ["content/yandex-music-tracker.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open popup",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "simple-popup@example.com",
      "strict_min_version": "109.0"
    }
  }
}

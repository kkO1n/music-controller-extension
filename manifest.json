{
  "manifest_version": 3,
  "name": "Yandex Music Remote Control",
  "version": "0.1.0",
  "description": "Shows current Yandex Music track, controls playback from the popup, and supports Telegram remote commands.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://music.yandex.ru/*", "https://api.telegram.org/*"],
  "background": {
    "scripts": [
      "background/core.js",
      "background/connection-fsm.js",
      "background/action-icon-service.js",
      "background/telegram-api-service.js",
      "background/config-service.js",
      "background/player-gateway.js",
      "background/status-message-service.js",
      "background/telegram-update-handlers.js",
      "background/polling-controller.js",
      "background/main.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://music.yandex.ru/*"],
      "js": ["content/yandex-music-tracker.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Yandex Music Remote",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/yandex-music-logo-disconnected-16.png",
      "32": "icons/yandex-music-logo-disconnected-32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "yandex-music-remote@example.com",
      "data_collection_permissions": {
        "required": ["websiteActivity", "websiteContent"]
      },
      "strict_min_version": "140.0"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
